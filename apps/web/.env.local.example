# Dify integration
# Base URL of the Dify API (no trailing slash, no /v1 needed below — added in code)
DIFY_API_URL=http://192.168.1.15/v1
# API key from the Dify app (Console > App > API Access)
DIFY_API_KEY=

# Deployment guard: use "development" locally. Set to "production" in the
# hosted environment to require secure auth, Supabase, Paddle, and runtime
# credential configuration.
AIO_DEPLOYMENT_ENV=development

# Supabase (Auth, registry, Vault, Storage — see BUILD_SPEC.md §5/§6)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth: configured in Supabase Dashboard, NOT here.
#   1. Google Cloud Console > APIs & Services > Credentials
#      - Create OAuth 2.0 Client ID (Web application)
#      - Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
#   2. Supabase Dashboard > Authentication > Providers > Google
#      - Enable, paste Client ID + Client Secret from step 1
#   3. Supabase Dashboard > Authentication > URL Configuration
#      - Site URL: http://192.168.88.157:3000 (dev) / production domain
#      - Redirect URLs: add <site-url>/auth/callback

# Hermes gateway (dev, single-profile — BUILD_SPEC.md §12 step 2)
# Server-side only. Forwarded as `Authorization: Bearer` to http://127.0.0.1:8642/v1/chat/completions.
# Value: API_SERVER_KEY from Aio_harness/aio-home/profiles/aio/.env
HERMES_DEV_API_SERVER_KEY=

# Local auth bypass. Never enable when AIO_DEPLOYMENT_ENV=production.
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# Paddle Billing. Required in production.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_STARTER=
PADDLE_PRICE_ID_PRO=
PADDLE_PRICE_ID_BUSINESS=
PADDLE_PRICE_ID_TOPUP=

# OpenRouter Management/Provisioning API key (Q15/Q41) — from
# openrouter.ai/settings/management-keys. Distinct from the regular
# OPENROUTER_API_KEY used for chat completions: this one can ONLY create,
# read, update, and delete other API keys via OpenRouter's Provisioning API.
# When set, every newly provisioned customer profile gets its own OpenRouter
# key with a hard monthly spend ceiling (per-tier limit in pricing.ts). When
# unset, all customers fall back to sharing the dev OPENROUTER_API_KEY above
# (Phase-1 placeholder behavior, no per-customer ceiling).
OPENROUTER_PROVISIONING_KEY=

# Langfuse (telemetry span export — see apps/web/src/lib/aio/telemetry/).
# Optional: unset means telemetry.ts falls back to no-op/OTEL_DEBUG as before.
# One project for the whole app (not per-Hermes-profile). Get keys from
# Langfuse Cloud project settings.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
